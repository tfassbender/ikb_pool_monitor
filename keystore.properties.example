# Copy this file to `keystore.properties` (gitignored) and fill in real values.
# Generate the keystore once with:
#   keytool -genkeypair -v `
#     -keystore "$env:USERPROFILE\keystores\ikb-pool-monitor.jks" `
#     -alias ikb-pool-monitor `
#     -keyalg RSA -keysize 2048 -validity 36500
#
# storeFile uses forward slashes even on Windows.

storeFile=C:/Users/YOU/keystores/ikb-pool-monitor.jks
storePassword=CHANGE_ME
keyAlias=ikb-pool-monitor
keyPassword=CHANGE_ME
